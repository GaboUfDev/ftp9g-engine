# ============================================================================
# .gitattributes — Git LFS para Unreal Engine 5
# Todo asset binario va a LFS para no inflar el repo.
# ============================================================================

# --- Normalización de fin de línea ---------------------------------------
* text=auto eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Código fuente (texto plano, diff legible)
*.cpp text diff=cpp
*.h text diff=cpp
*.hpp text diff=cpp
*.cs text diff=csharp
*.json text
*.md text
*.uproject text
*.uplugin text
*.ini text
*.txt text
*.yaml text
*.yml text

# ============================================================================
# Git LFS — assets binarios de UE5
# ============================================================================

# --- UE5 nativos ----------------------------------------------------------
*.uasset filter=lfs diff=lfs merge=lfs -text
*.umap filter=lfs diff=lfs merge=lfs -text

# --- Modelos 3D -----------------------------------------------------------
*.fbx filter=lfs diff=lfs merge=lfs -text
