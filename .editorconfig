# EditorConfig — estilo unificado para FTP9G
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 4

[*.{cpp,h,hpp,cs}]
indent_style = tab
indent_size = 4

[*.{json,yml,yaml,md}]
indent_style = space
indent_size = 2

[*.{bat,cmd,ps1}]
end_of_line = crlf
